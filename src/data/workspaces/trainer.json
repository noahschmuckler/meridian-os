{
  "id": "trainer",
  "title": "Trainer",
  "icon": { "glyph": "🎓", "tint": "#0F6B42" },
  "cells": [],
  "standalones": [
    {
      "id": "chat",
      "type": "llm-chat",
      "title": "Trainer chat",
      "props": {
        "greeting": "Training Dr. Patel today. Day 1 covered SmartPhrases + In-Basket; LOS rubric + HCC missed.",
        "defaultPersona": "trainer",
        "brain": {
          "miniBubbles": [
            { "id": "mini-hub", "label": "Patel hub state", "source": "patel.hub_state", "pinned": true },
            { "id": "mini-last", "label": "Last session summary", "source": "patel.last_session", "pinned": false },
            { "id": "mini-sp", "label": "Recommended SmartPhrases", "source": "patel.smartphrases", "pinned": false }
          ],
          "hydrationRules": { "onAttach": "auto-add", "onDrop": "auto-add" }
        }
      },
      "resize": { "initial": "l", "states": {} }
    },
    {
      "id": "blueprint",
      "type": "blueprint-tree",
      "title": "Blueprint",
      "props": {
        "items": { "$seed": "patel.blueprint" },
        "hubState": { "$seed": "patel.hub_state_full" }
      },
      "resize": { "initial": "l", "states": {} }
    },
    {
      "id": "followups",
      "type": "follow-ups-rail",
      "title": "Follow-ups",
      "props": { "items": { "$seed": "patel.followups" } },
      "resize": { "initial": "m", "states": {} }
    },
    {
      "id": "dossier",
      "type": "provider-dossier",
      "title": "Dr. Patel — Dossier",
      "props": { "dossier": { "$seed": "patel.dossier" } },
      "resize": { "initial": "m", "states": {} }
    },
    {
      "id": "questionnaire",
      "type": "questionnaire",
      "title": "Week-0 Questionnaire",
      "props": {},
      "resize": { "initial": "s", "states": {} }
    },
    {
      "id": "dropzone",
      "type": "dropzone",
      "title": "Drop transcript",
      "props": {},
      "resize": { "initial": "s", "states": {} }
    },
    {
      "id": "generated",
      "type": "generated-sessions-rail",
      "title": "Generated sessions",
      "props": { "sessions": { "$seed": "patel.generated_modules" } },
      "resize": { "initial": "s", "states": {} }
    }
  ],
  "layoutHints": {
    "grid": { "cols": 12, "rows": 8 },
    "placements": {
      "chat":          { "col": 0, "row": 0, "width": 5, "height": 6 },
      "blueprint":     { "col": 5, "row": 0, "width": 7, "height": 4 },
      "dossier":       { "col": 5, "row": 4, "width": 4, "height": 2 },
      "questionnaire": { "col": 9, "row": 4, "width": 3, "height": 2 },
      "followups":     { "col": 0, "row": 6, "width": 5, "height": 2 },
      "dropzone":      { "col": 5, "row": 6, "width": 3, "height": 2 },
      "generated":     { "col": 8, "row": 6, "width": 4, "height": 2 }
    }
  },
  "scripted": {
    "onMount": [],
    "onSearch": {},
    "onDrop": {}
  },
  "seed": { "sources": ["patel-cohort"] }
}
